# ═══════════════════════════════════════════════
# Synkron — API Configuration
# ═══════════════════════════════════════════════
# Get your credentials from your e-commerce platform admin panel.
# Copy this file to .env and fill in your values:
#   cp .env.example .env

IKAS_CLIENT_ID=your_client_id_here
IKAS_CLIENT_SECRET=your_client_secret_here
IKAS_STORE_SLUG=your_store_slug_here

# API Endpoints (defaults work for most users)
IKAS_AUTH_URL=https://api.myikas.com/api/admin/oauth/token
IKAS_GRAPHQL_URL=https://api.myikas.com/api/v2/admin/graphql
